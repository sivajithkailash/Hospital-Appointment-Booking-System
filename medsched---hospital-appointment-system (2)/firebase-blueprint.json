{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Patient appointment details",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorName": { "type": "string" },
        "department": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "token": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorName", "date", "time", "status", "token"]
    },
    "MedicalRecord": {
      "title": "Medical Record",
      "description": "Patient medical history",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "diagnosis": { "type": "string" },
        "notes": { "type": "string" },
        "doctorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "date", "diagnosis", "doctorName"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Patient prescriptions",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "medicines": { "type": "array" },
        "doctorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "date", "medicines", "doctorName"]
    },
    "LabReport": {
      "title": "Lab Report",
      "description": "Patient lab test results",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "testName": { "type": "string" },
        "result": { "type": "string" },
        "status": { "type": "string" },
        "doctorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "date", "testName", "result", "status"]
    },
    "Billing": {
      "title": "Billing",
      "description": "Patient billing and payments",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "date", "amount", "status"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile and credentials",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "string" },
        "certificateUrl": { "type": "string" },
        "phone": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "specialty"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Patient appointments"
    },
    "/medicalRecords/{recordId}": {
      "schema": "MedicalRecord",
      "description": "Patient medical records"
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Patient prescriptions"
    },
    "/labReports/{reportId}": {
      "schema": "LabReport",
      "description": "Patient lab reports"
    },
    "/billing/{billId}": {
      "schema": "Billing",
      "description": "Patient billing records"
    }
  }
}
